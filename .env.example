# ──────────────────────────────────────────────
# TaskBot — пример конфигурации
# Скопируйте в .env и заполните своими значениями
# ──────────────────────────────────────────────

# Токен бота от @BotFather (обязательно)
BOT_TOKEN=your_bot_token_here

# Белый список пользователей (через запятую, без @)
# Пусто = доступ для всех
ALLOWED_USERS=username1,username2

# Администраторы (могут удалять задачи)
ADMIN_USERS=your_username

# База данных
DB_PATH=/app/data/tasks.db

# Напоминания о дедлайнах (в минутах)
REMINDER_BEFORE_MINUTES=60

# Веб-дашборд
WEB_HOST=0.0.0.0
WEB_PORT=5000
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme
